# Ignore the local virtual environment
venv/
.venv/
env/

# Ignore Python cache files
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore local data and artifacts (so AWS doesn't get your local junk)
artifacts/
logs/
*.db

# Ignore environment secrets (Crucial for security!)
.env
.git/
.github/

# Ignore IDE settings
.vscode/
.idea/